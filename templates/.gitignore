# Claude Code Backup .gitignore
#
# For use in your PRIVATE backup repository.
# This repo will contain sensitive data (MCP configs, OAuth tokens).

# Credentials that should never be standalone files
.credentials.json
*.key
*.pem
id_rsa
id_ed25519
id_ecdsa
.env
.env.*

# Temporary files
*.tmp
*.bak
*.swp
*.swo
*~
*.orig
*.rej

# OS files
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# Editor files
.vscode/
.idea/
*.code-workspace
